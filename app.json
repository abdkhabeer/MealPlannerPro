{
  "expo": {
    "name": "KitchenIQ Pro",
    "slug": "MealPlannerPro",
    "scheme": "kitcheniqpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abdulkhabeer.mealplannerpro",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE4"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KitchenIQ Pro to access your photos to upload recipe images.",
          "cameraPermission": "Allow KitchenIQ Pro to use your camera to photograph recipes."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08127314-2ff3-4710-97e4-4e289f474311"
      }
    }
  }
}
